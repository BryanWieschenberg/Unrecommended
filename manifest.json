{
  "manifest_version": 3,
  "name": "Unrecommended",
  "version": "1.1.0",
  "description": "Removes algorithmic feeds and distractions from LinkedIn and YouTube so you can browse intentionally.",
  "permissions": ["scripting", "tabs"],
  "host_permissions": ["https://*.linkedin.com/*", "https://*.youtube.com/*", "https://*.instagram.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Unrecommended",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content-youtube.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
